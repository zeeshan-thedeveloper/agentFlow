# ──────────────────────────────────────────────
# Database  (matches docker-compose defaults)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://agent_user:agent_pass@localhost:15432/agentflow

# ──────────────────────────────────────────────
# Redis  (matches docker-compose defaults)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# API server
# ──────────────────────────────────────────────
PORT=3001

# ──────────────────────────────────────────────
# Frontend  (exposed to browser, prefix required)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret
API_KEY_ENCRYPTION_SECRET=replace-with-a-random-32-byte-secret
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
